# GA4 property for cmfmasonry.com — do NOT reuse calmantel's G-ZVJ97TZNZN
NEXT_PUBLIC_GA4_ID=G-XXXXXXXXXX

# CallRail dynamic number swap — OPTIONAL. The business has a single CallRail
# Company (736627927, same one calmantel.com uses) with a dedicated tracking
# number for masonry ("Google Ads Assets - Masonry" pool) inside it — there's
# no separate Company to create. That tracking number, (714) 886-3179, is
# hardcoded site-wide as BUSINESS.phone in src/lib/business-data.ts, which
# already gives clean call attribution without needing this swap script.
# Only set this if you later want per-channel dynamic number swapping on top
# of the static number (requires configuring matching Source rules in
# CallRail so cmfmasonry.com visits reliably show the masonry number, not one
# of the business's other numbers).
NEXT_PUBLIC_CALLRAIL_COMPANY_ID=

# Web3Forms access key for the /estimate lead form (create a new key, do not
# reuse calmantel's). Submitted directly from the browser to Web3Forms — their
# access keys are designed to be public-facing, not secret API keys — because
# a server-side proxy from Vercel's datacenter IPs got blocked/challenged by
# Web3Forms and returned non-JSON responses. Must be NEXT_PUBLIC_ to reach the
# client bundle.
NEXT_PUBLIC_WEB3FORMS_ACCESS_KEY=
